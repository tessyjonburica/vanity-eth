{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        },
        {
            "src": "api/wallet-recurrence.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/wallet-recurrence",
            "destination": "/api/wallet-recurrence.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
